{
  "expo": {
    "name": "Speech Transcriber Mobile",
    "slug": "speech_transcriber_mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon/transcriber-icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/app-icon/transcriber-icon.png"
    },
    "android": {
      "package": "com.speechtranscriber.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/app-icon/transcriber-icon.png",
        "backgroundImage": "./assets/app-icon/transcriber-icon.png",
        "monochromeImage": "./assets/app-icon/transcriber-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/app-icon/transcriber-icon.png"
    },
    "plugins": [
      "expo-speech-recognition",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/app-icon/transcriber-icon.png",
          "imageWidth": 140,
          "android": {
            "image": "./assets/app-icon/transcriber-icon.png",
            "imageWidth": 140
          }
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
